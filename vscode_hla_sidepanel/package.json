{
  "name": "hussain-livetorch-architect-sidepanel",
  "displayName": "Hussain LiveTorch Architect Panel",
  "description": "Live PyTorch architecture diagram side panel for VS Code.",
  "version": "0.1.0",
  "publisher": "hussain",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:hla.diagramView",
    "onCommand:hla.refreshDiagram",
    "onCommand:hla.toggleRealtime",
    "onCommand:hla.openPanel",
    "onCommand:hla.openDiagramBeside"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hla",
          "title": "HLA",
          "icon": "media/hla-icon.svg"
        }
      ]
    },
    "views": {
      "hla": [
        {
          "id": "hla.diagramView",
          "name": "Architecture Live Diagram",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "hla.openPanel",
        "title": "HLA: Open Side Panel"
      },
      {
        "command": "hla.openDiagramBeside",
        "title": "HLA: Open Diagram Beside"
      },
      {
        "command": "hla.refreshDiagram",
        "title": "HLA: Refresh Diagram"
      },
      {
        "command": "hla.toggleRealtime",
        "title": "HLA: Toggle Realtime Updates"
      }
    ],
    "keybindings": [
      {
        "command": "hla.openPanel",
        "key": "ctrl+alt+h"
      },
      {
        "command": "hla.openDiagramBeside",
        "key": "ctrl+alt+d"
      },
      {
        "command": "hla.refreshDiagram",
        "key": "ctrl+alt+r",
        "when": "editorLangId == python"
      },
      {
        "command": "hla.toggleRealtime",
        "key": "ctrl+alt+t",
        "when": "editorLangId == python"
      }
    ],
    "configuration": {
      "title": "Hussain LiveTorch Architect",
      "properties": {
        "hla.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run HLA analyzer."
        },
        "hla.analyzerCommand": {
          "type": "string",
          "default": "hla",
          "description": "Primary analyzer command. Defaults to hla CLI; falls back to python -m hussain_livetorch_architect."
        },
        "hla.autoUpdateOnType": {
          "type": "boolean",
          "default": true,
          "description": "Auto-update the diagram while typing (debounced)."
        },
        "hla.updateDebounceMs": {
          "type": "number",
          "default": 600,
          "description": "Debounce delay for typing updates."
        },
        "hla.verifyOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run runtime verification on save. Slower but more accurate."
        },
        "hla.renderer": {
          "type": "string",
          "enum": [
            "auto",
            "d2",
            "graphviz"
          ],
          "default": "auto",
          "description": "Rendering backend for exported diagram."
        },
        "hla.theme": {
          "type": "string",
          "enum": [
            "journal-light",
            "journal-gray",
            "journal-minimal"
          ],
          "default": "journal-light",
          "description": "Theme used for the diagram renderer."
        },
        "hla.layout": {
          "type": "string",
          "default": "elk",
          "description": "Layout engine. Use elk for D2 journal-style diagrams."
        },
        "hla.inputShape": {
          "type": "string",
          "default": "1,3,224,224",
          "description": "Input shape used when verify-on-save is enabled."
        },
        "hla.pad": {
          "type": "number",
          "default": 40,
          "description": "Diagram canvas padding."
        },
        "hla.className": {
          "type": "string",
          "default": "",
          "description": "Optional nn.Module class name to analyze. Leave empty to auto-select first class."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "devhost": "code --extensionDevelopmentPath . --new-window",
    "package:vsix": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.2"
  }
}
