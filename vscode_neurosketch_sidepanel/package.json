{
  "name": "neurosketch-sidepanel",
  "displayName": "NeuroSketch Panel",
  "description": "Live deep-learning architecture diagram side panel for VS Code.",
  "version": "0.1.0",
  "publisher": "musawer1214",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:neurosketch.diagramView",
    "onCommand:neurosketch.refreshDiagram",
    "onCommand:neurosketch.toggleRealtime",
    "onCommand:neurosketch.openPanel",
    "onCommand:neurosketch.openDiagramBeside"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "neurosketch",
          "title": "NeuroSketch",
          "icon": "media/neurosketch-icon.svg"
        }
      ]
    },
    "views": {
      "neurosketch": [
        {
          "id": "neurosketch.diagramView",
          "name": "Architecture Live Diagram",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "neurosketch.openPanel",
        "title": "NeuroSketch: Open Side Panel"
      },
      {
        "command": "neurosketch.openDiagramBeside",
        "title": "NeuroSketch: Open Diagram Beside"
      },
      {
        "command": "neurosketch.refreshDiagram",
        "title": "NeuroSketch: Refresh Diagram"
      },
      {
        "command": "neurosketch.toggleRealtime",
        "title": "NeuroSketch: Toggle Realtime Updates"
      }
    ],
    "keybindings": [
      {
        "command": "neurosketch.openPanel",
        "key": "ctrl+alt+h"
      },
      {
        "command": "neurosketch.openDiagramBeside",
        "key": "ctrl+alt+d"
      },
      {
        "command": "neurosketch.refreshDiagram",
        "key": "ctrl+alt+r",
        "when": "editorLangId == python"
      },
      {
        "command": "neurosketch.toggleRealtime",
        "key": "ctrl+alt+t",
        "when": "editorLangId == python"
      }
    ],
    "configuration": {
      "title": "NeuroSketch",
      "properties": {
        "neurosketch.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run the NeuroSketch analyzer."
        },
        "neurosketch.analyzerCommand": {
          "type": "string",
          "default": "neurosketch",
          "description": "Primary analyzer command. Defaults to the neurosketch CLI; falls back to python -m neurosketch."
        },
        "neurosketch.autoUpdateOnType": {
          "type": "boolean",
          "default": true,
          "description": "Auto-update the diagram while typing (debounced)."
        },
        "neurosketch.updateDebounceMs": {
          "type": "number",
          "default": 600,
          "description": "Debounce delay for typing updates."
        },
        "neurosketch.verifyOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run runtime verification on save. Slower but more accurate."
        },
        "neurosketch.renderer": {
          "type": "string",
          "enum": [
            "auto",
            "d2",
            "graphviz"
          ],
          "default": "auto",
          "description": "Rendering backend for exported diagram."
        },
        "neurosketch.theme": {
          "type": "string",
          "enum": [
            "journal-light",
            "journal-gray",
            "journal-minimal"
          ],
          "default": "journal-light",
          "description": "Theme used for the diagram renderer."
        },
        "neurosketch.layout": {
          "type": "string",
          "default": "elk",
          "description": "Layout engine. Use elk for D2 journal-style diagrams."
        },
        "neurosketch.inputShape": {
          "type": "string",
          "default": "1,3,224,224",
          "description": "Input shape used when verify-on-save is enabled."
        },
        "neurosketch.pad": {
          "type": "number",
          "default": 40,
          "description": "Diagram canvas padding."
        },
        "neurosketch.className": {
          "type": "string",
          "default": "",
          "description": "Optional nn.Module class name to analyze. Leave empty to auto-select first class."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "devhost": "code --extensionDevelopmentPath . --new-window",
    "package:vsix": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.2"
  }
}
